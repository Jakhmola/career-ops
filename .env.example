# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── Aggregator job sources (scan.mjs) ────────────────────────────────────────
# Optional. The zero-token scanner polls these query-based sources alongside the
# tracked companies. Leave a key blank to keep that source dormant (no error).

# Adzuna (free) — broad NL/EU coverage with salary data.
# Sign up at https://developer.adzuna.com/ → create an app → copy the IDs.
# Without these, the Adzuna aggregator is skipped.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via OpenWebNinja (free tier, limited ~200 calls/month).
# Sign up at https://app.openwebninja.com/api/jsearch → subscribe (free tier) →
# copy your API key. It is sent as the `x-api-key` header. The variable keeps
# the name RAPIDAPI_KEY (JSearch's original home) but holds the OpenWebNinja key.
# The ONLY source that surfaces LinkedIn / Indeed / Glassdoor (via Google for
# Jobs). Ships disabled by default in portals.yml (aggregators.jsearch.enabled).
RAPIDAPI_KEY=

# Careerjet (free) — broad NL/EU coverage with role-phrase queries.
# Sign up at https://www.careerjet.com/partners/api/ → request an API key.
# Auth is HTTP Basic (username = key, password = empty). The provider builds
# the Authorization header automatically. Allows up to 1000 calls/hour.
CAREERJET_KEY=

# Jooble (free) — global job aggregator, strong NL/EU coverage.
# Sign up at https://jooble.org/api/about → request an API key (~36-char GUID).
# Auth: key is embedded as a URL path segment (POST https://jooble.org/api/<KEY>).
# Free tier available; no published hard cap — set monthly_cap in portals.yml.
JOOBLE_API_KEY=

# Arbeitnow — no key required; works out of the box (no variable needed).

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
